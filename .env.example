# ─────────────────────────────────────────────────
#  Discord Music Bot — Environment Variables
# ─────────────────────────────────────────────────

# Your bot token from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# The ID of the text channel where users type song names
# Right-click the channel → Copy Channel ID (Developer Mode must be ON)
MUSIC_CHANNEL_ID=your_channel_id_here

# Your Discord application/client ID (for registering slash commands)
CLIENT_ID=your_client_id_here

# Your server (guild) ID (for fast slash command registration during dev)
GUILD_ID=your_guild_id_here
